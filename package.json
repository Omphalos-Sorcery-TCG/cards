{
  "name": "@omphalos/cards",
  "version": "0.1.0",
  "description": "Canonical card data, domain types, deck validation, and a data-loading client for Sorcery: Contested Realm (Omphalos).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "files": [
    "src",
    "scripts",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cards:download": "python scripts/download_cards.py",
    "cards:split": "node scripts/split-cards.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
